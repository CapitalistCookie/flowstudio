# ──────────────────────────────────────────────
# FlowStudio — Unified Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# ─── Auth (Clerk) ─────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=     # Required: from Clerk dashboard
CLERK_SECRET_KEY=                       # Required: from Clerk dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── SpacetimeDB ──────────────────────────────
STDB_HOST=localhost:3000               # Local: localhost:3000 | Prod: stdb.flowstudio.ai
STDB_MODULE=flowstudio
STDB_INTERNAL_HOST=localhost           # Workers use this (same as STDB_HOST for local dev)
STDB_INTERNAL_PORT=3000
NEXT_PUBLIC_STDB_HOST=ws://localhost:3000   # Frontend WebSocket URL
NEXT_PUBLIC_STDB_MODULE=flowstudio

# ─── GCP / GCS ───────────────────────────────
GCP_PROJECT_ID=                        # Required: GCP project ID
GCP_REGION=us-east4
GCS_BUCKET=flowstudio-assets           # Required: GCS bucket for assets
GOOGLE_APPLICATION_CREDENTIALS=        # Path to service account JSON (local dev only)

# ─── AI / LLM ────────────────────────────────
LLM_PROVIDER=gemini                    # gemini | anthropic
GOOGLE_AI_API_KEY=                     # Required: for Gemini (video-understanding, intent, narrative, edit)
DEEPGRAM_API_KEY=                      # Required: for speech transcription worker

# Vertex AI (optional, for Anthropic Claude via Vertex)
VERTEX_PROJECT_ID=                     # Falls back to GCP_PROJECT_ID
VERTEX_REGION=us-central1
VERTEX_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT=                  # Same as GCP_PROJECT_ID (used by some SDKs)
GOOGLE_CLOUD_PROJECT_NUMBER=           # From GCP console
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Railtracks Gateway ──────────────────────
RAILTRACKS_GATEWAY_PORT=8000
NEXT_PUBLIC_RAILTRACKS_URL=http://localhost:8000
GATEWAY_API_KEY=                           # Optional: set to require X-API-Key header
GATEWAY_RATE_LIMIT_RPM=30                 # Rate limit: requests per minute per IP
ALLOWED_ORIGINS=http://localhost:3000      # Comma-separated CORS origins

# ─── Workers (set per-worker in docker/scripts)
WORKER_NAME=audio-extract
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=1000
HEALTH_PORT=8080

# ─── Frontend Upload ─────────────────────────
NEXT_PUBLIC_UPLOAD_FUNCTION_URL=http://localhost:8081

# ─── Infrastructure (deploy only) ────────────
ARTIFACT_REGISTRY=                     # us-east4-docker.pkg.dev/PROJECT/flowstudio
STDB_VM_NAME=flowstudio-stdb
STDB_VM_ZONE=us-east4-c
STDB_DOMAIN=stdb.flowstudio.ai
STDB_CERTBOT_EMAIL=admin@flowstudio.ai
VPC_CONNECTOR_NAME=flowstudio-vpc
