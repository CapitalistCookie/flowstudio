# ──────────────────────────────────────────────
# FlowStudio Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# ── SpacetimeDB ──────────────────────────────
STDB_HOST=stdb.flowstudio.ai
STDB_MODULE=flowstudio
# Internal (Cloud Run → GCE via VPC connector)
STDB_INTERNAL_HOST=10.128.0.100
STDB_INTERNAL_PORT=3000

# ── GCP ──────────────────────────────────────
GCP_PROJECT_ID=lyrical-epigram-484715-v6
GCP_REGION=us-east4
GCS_BUCKET=flowstudio-assets
ARTIFACT_REGISTRY=us-east4-docker.pkg.dev/lyrical-epigram-484715-v6/flowstudio

# ── API Keys ─────────────────────────────────
DEEPGRAM_API_KEY=
GOOGLE_AI_API_KEY=
VERTEX_REGION=us-central1

# ── Worker Config ────────────────────────────
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=1000
HEALTH_PORT=8080

# ── Client ───────────────────────────────────
NEXT_PUBLIC_STDB_HOST=wss://stdb.flowstudio.ai
NEXT_PUBLIC_STDB_MODULE=flowstudio
NEXT_PUBLIC_UPLOAD_FUNCTION_URL=https://us-east4-lyrical-epigram-484715-v6.cloudfunctions.net

# ── Infrastructure ───────────────────────────
STDB_VM_NAME=flowstudio-stdb
STDB_VM_ZONE=us-east4-c
STDB_DOMAIN=stdb.flowstudio.ai
STDB_CERTBOT_EMAIL=admin@flowstudio.ai
VPC_CONNECTOR_NAME=flowstudio-vpc
