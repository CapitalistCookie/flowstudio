{
  "name": "flowstudio",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered video editing platform",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:gateway": "cd packages/railtracks-gateway && uvicorn app.main:app --reload --port 8000",
    "dev:stdb": "docker compose up stdb -d && sleep 3 && spacetime publish flowstudio --path packages/stdb-module",
    "dev:core": "docker compose --profile core up -d",
    "dev:full": "docker compose --profile full up -d",
    "dev:down": "docker compose --profile full down",
    "stdb:dev": "cd packages/stdb-module && pnpm run stdb:publish",
    "stdb:logs": "cd packages/stdb-module && pnpm run stdb:logs"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "happy-dom": "^20.8.4",
    "vitest": "^4.1.0"
  }
}
