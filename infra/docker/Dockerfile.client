FROM node:24-slim AS base
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY tsconfig.base.json ./
COPY packages/shared/ packages/shared/
COPY frontend/ frontend/

RUN npm install -g pnpm@9
RUN pnpm install --frozen-lockfile --filter @flowstudio/shared --filter frontend

ARG NEXT_PUBLIC_STDB_HOST=wss://stdb.flowstudio.ai
ARG NEXT_PUBLIC_STDB_MODULE=flowstudio
ARG NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
ENV NEXT_PUBLIC_STDB_HOST=$NEXT_PUBLIC_STDB_HOST
ENV NEXT_PUBLIC_STDB_MODULE=$NEXT_PUBLIC_STDB_MODULE
ENV NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=$NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY

RUN cd frontend && pnpm run build

FROM node:24-slim AS production
WORKDIR /app

COPY --from=base /app/frontend/.next/standalone ./
COPY --from=base /app/frontend/.next/static ./frontend/.next/static
COPY --from=base /app/frontend/public ./frontend/public

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
EXPOSE 3000

CMD ["node", "frontend/server.js"]
