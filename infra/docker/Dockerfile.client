FROM node:20.18-slim AS base
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY tsconfig.base.json ./
COPY packages/shared/ packages/shared/
COPY packages/client/ packages/client/

RUN corepack enable && corepack prepare pnpm@9 --activate
RUN pnpm install --frozen-lockfile --filter @flowstudio/shared --filter @flowstudio/client

ARG NEXT_PUBLIC_STDB_HOST=wss://stdb.flowstudio.ai
ARG NEXT_PUBLIC_STDB_MODULE=flowstudio
ARG NEXT_PUBLIC_UPLOAD_FUNCTION_URL=
ENV NEXT_PUBLIC_STDB_HOST=$NEXT_PUBLIC_STDB_HOST
ENV NEXT_PUBLIC_STDB_MODULE=$NEXT_PUBLIC_STDB_MODULE
ENV NEXT_PUBLIC_UPLOAD_FUNCTION_URL=$NEXT_PUBLIC_UPLOAD_FUNCTION_URL

RUN pnpm --filter @flowstudio/shared run build
RUN pnpm --filter @flowstudio/client run build

FROM node:20.18-slim AS production
WORKDIR /app

COPY --from=base /app/packages/client/.next ./packages/client/.next
COPY --from=base /app/packages/client/package.json ./packages/client/
COPY --from=base /app/node_modules ./node_modules
COPY --from=base /app/packages/shared/dist ./packages/shared/dist
COPY --from=base /app/packages/shared/package.json ./packages/shared/

WORKDIR /app/packages/client
ENV NODE_ENV=production
EXPOSE 3000

CMD ["/app/node_modules/.bin/next", "start"]
