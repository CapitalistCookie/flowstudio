{
  "name": "@flowstudio/stdb-module",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "stdb:publish": "~/.local/bin/spacetime publish flowstudio -p . -s http://localhost:3002 -y -c always",
    "stdb:logs": "~/.local/bin/spacetime logs flowstudio",
    "stdb:generate:frontend": "~/.local/bin/spacetime generate --lang typescript --out-dir ../../claudeFrontend/src/module_bindings --project-path .",
    "stdb:generate:workers": "~/.local/bin/spacetime generate --lang typescript --out-dir ../workers/shared/src/module_bindings --project-path ."
  },
  "devDependencies": {
    "typescript": "5.7.3"
  }
}
